{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "semanticCommits": true,
  "semanticCommitType": "chore",
  "flux": {
    "fileMatch": ["\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": [
      "\\.yaml$",
      "kubernetes/.+\\.yaml$"
    ]
  },
  "regexManagers": [
    {
      "fileMatch": ["kubernetes/apps/base/immich/release.yaml"],
      "matchStrings": [
        "tag:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "ghcr.io/immich-app/immich-server",
      "datasourceTemplate": "docker"
    },
    {
      "fileMatch": ["(^|/)plex/.*\\.yaml$"],
      "matchStrings": [
        "image:\\s*plexinc/pms-docker:(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "plexinc/pms-docker",
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["plexinc/pms-docker"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+\\.\\d+-[a-f0-9]+$/"
    },
  {
    "matchPackagePatterns": ["quay.io/jetstack/cert-manager-.*"],
    "groupName": "cert-manager"
  }
  ]
}
